pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: kubectl
    image: alpine:3.20
    command: ["cat"]
    tty: true
'''
        }
    }

    stages {
        stage('Install tools') {
            steps {
                container('kubectl') {
                    sh '''
                        kubectl version --client
                        echo hello
                    '''
                }
            }
        }
    }
}
