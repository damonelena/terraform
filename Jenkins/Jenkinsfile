pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: kubectl
    image: alpine:3.20
    command: ["cat"]
    tty: true
'''
        }
    }

    stages {
        stage('Install tools') {
            steps {
                container('kubectl') {
                    sh '''
                        apk add --no-cache curl bash
                        curl -LO https://dl.k8s.io/release/v1.29.0/bin/linux/amd64/kubectl
                        chmod +x kubectl
                        mv kubectl /usr/local/bin/
                        kubectl version --client
                        echo hello
                    '''
                }
            }
        }
    }
}
